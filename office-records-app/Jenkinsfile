pipeline {
    agent any

    stages {

        stage('Deploy Backend') {
            steps {
                sh 'zip -r lambda.zip backend/*'
                sh 'aws lambda update-function-code --function-name office-records-backend --zip-file fileb://lambda.zip --region us-east-2'
            }
        }

        stage('Deploy Frontend') {
            steps {
                sh 'aws s3 sync frontend/ s3://office-records-frontend --delete --region us-east-2'
            }
        }

    }
}
